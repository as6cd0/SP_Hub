function splib:RegisterPremiumElement(instance)
    if not instance then return end
    table.insert(self.PremiumElements, instance)
end

local function ApplyPremiumVisual(self)
    for _, inst in ipairs(self.PremiumElements) do
        pcall(function()
            if typeof(inst) == "Instance" then
                if inst:IsA("GuiObject") then
                    inst.Visible = self.IsPremium
                else
                    if inst.Parent and not self.IsPremium then
                        inst._saved_parent = inst.Parent
                        inst.Parent = nil
                    elseif inst._saved_parent and self.IsPremium then
                        inst.Parent = inst._saved_parent
                        inst._saved_parent = nil
                    end
                end
            end
        end)
    end
end

function splib:SetPremium(state)
    state = state and true or false
    if self.IsPremium == state then return end

    self.IsPremium = state

    safeWriteFile("splib_premium.dat", state and "1" or "0")

    ApplyPremiumVisual(self)
    self._PremiumChanged:Fire(state)
end

function splib:LoadPremium()
    local data = safeReadFile("splib_premium.dat")
    self.IsPremium = (data == "1") and true or false
    ApplyPremiumVisual(self)
end


local function safeHttpGet(url)
    local ok, result = pcall(function()
        return game:HttpGet(url)
    end)
    if ok and type(result) == "string" and result ~= "" then
        return result
    end
    return nil
end

local function safeLoadRemoteTable(url, fallback)
    local source = safeHttpGet(url)
    if type(source) ~= "string" then
        return fallback
    end

    local okChunk, chunk = pcall(loadstring, source)
    if not okChunk or type(chunk) ~= "function" then
        return fallback
    end

    local okData, data = pcall(chunk)
    if okData and type(data) == "table" then
        return data
    end
    return fallback
end

local function normalizeThemes(themeTable)
    local normalized = {}

    if type(themeTable) == "table" then
        for themeName, themeData in pairs(themeTable) do
            if type(themeName) == "string" and type(themeData) == "table" then
                local theme = cloneDefaultTheme()
                for key, value in pairs(themeData) do
                    theme[key] = value
                end
                normalized[themeName] = theme
            end
        end
    end

    if next(normalized) == nil then
        normalized.Red = cloneDefaultTheme()
    elseif type(normalized.Red) ~= "table" then
        normalized.Red = cloneDefaultTheme()
    end

    return normalized
end

local function normalizeIcons(iconTable)
    if type(iconTable) ~= "table" then
        return {}
    end
    return iconTable
end

local function safeIsFile(path)
    if type(isfile) ~= "function" then
        return false
    end
    local ok, result = pcall(isfile, path)
    return ok and result == true
end

local function safeReadFile(path)
    if type(readfile) ~= "function" then
        return nil
    end
    local ok, result = pcall(readfile, path)
    if ok and type(result) == "string" then
        return result
    end
    return nil
end

local function safeWriteFile(path, content)
    if type(writefile) ~= "function" then
        return false
    end
    return pcall(writefile, path, content)
end

local function safeIsFolder(path)
    if type(isfolder) ~= "function" then
        return false
    end
    local ok, result = pcall(isfolder, path)
    return ok and result == true
end

local function safeMakeFolder(path)
    if type(makefolder) ~= "function" then
        return false
    end
    return pcall(makefolder, path)
end

local function safeJSONDecode(content, fallback)
    if type(content) ~= "string" or content == "" then
        return fallback
    end
    local ok, decoded = pcall(function()
        return HttpService:JSONDecode(content)
    end)
    if ok and type(decoded) == "table" then
        return decoded
    end
    return fallback
end

local function safeJSONEncode(data, fallback)
    local ok, encoded = pcall(function()
        return HttpService:JSONEncode(data)
    end)
    if ok and type(encoded) == "string" then
        return encoded
    end
    return fallback or "{}"
end

local function safeReadJsonFile(path, fallback)
    local raw = safeReadFile(path)
    return safeJSONDecode(raw, fallback)
end

local function safeWriteJsonFile(path, data)
    return safeWriteFile(path, safeJSONEncode(data, "{}"))
end


    if total == 0 then
        animatePresetRow(false)
        animateFrameHeight(false)
        PresetsList.Visible = false
        PresetsList.ScrollingEnabled = false
        PresetsList.CanvasPosition = Vector2.new(0, 0)
        isPresetHovered = false
        setContainerScroll(true)
        return
    end

    local shrinkDelay = math.max(0, (total - collapseWhenRemain) * closeStepDelay)
    task.delay(shrinkDelay, function()
        animatePresetRow(false)
        animateFrameHeight(false)
    end)

    for k = 1, total do
        local idx = total - k + 1
        local b = buttons[idx]

        task.delay((k - 1) * closeStepDelay, function()
            CreateTween({b, "Size", UDim2.new(0, 0, 0, 8), 0.08})

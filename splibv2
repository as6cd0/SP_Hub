	local function isGeneralMatch(elemName, queryText)
		elemName = string.lower(elemName or "")
		queryText = string.lower(queryText or ""):match("^%s*(.-)%s*$") or ""
		if queryText == "" then return true end
		if elemName:find(queryText, 1, true) then return true end
		local compactElem = elemName:gsub("%s+", "")
		local compactQuery = queryText:gsub("%s+", "")
		if compactElem:find(compactQuery, 1, true) then return true end
		return false
	end

	local function escapeRichText(text)
		text = tostring(text or "")
		text = text:gsub("&", "&amp;")
		text = text:gsub("<", "&lt;")
		text = text:gsub(">", "&gt;")
		return text
	end

	local function getSearchElementOptions(elem)
		local provider = elem and elem.SearchProvider
		if type(provider) ~= "function" then
			return {}
		end

		local ok, result = pcall(provider)
		if not ok or type(result) ~= "table" then
			return {}
		end

		local options = {}
		for _, value in ipairs(result) do
			if value ~= nil then
				table.insert(options, tostring(value))
			end
		end
		return options
	end

	local function searchElementMatches(elem, queryText)
		if not elem then return false end
		if isGeneralMatch(elem.Name, queryText) then
			return true
		end

		for _, optionName in ipairs(getSearchElementOptions(elem)) do
			if isGeneralMatch(optionName, queryText) then
				return true
			end
		end
		return false
	end

	local function getMatchedSearchOptions(elem, queryText, limit)
		local matches = {}
		limit = tonumber(limit) or 2
		if (string.lower(queryText or ""):match("^%s*(.-)%s*$") or "") == "" then
			return matches
		end

		for _, optionName in ipairs(getSearchElementOptions(elem)) do
			if isGeneralMatch(optionName, queryText) then
				table.insert(matches, optionName)
				if #matches >= limit then
					break
				end
			end
		end
		return matches
	end


	local function getParentScrollingFrame(frame)
		local current = frame and frame.Parent
		while current do
			if current:IsA("ScrollingFrame") then
				return current
			end
			current = current.Parent
		end
		return nil
	end

	local activeSearchScrollTweens = setmetatable({}, {__mode = "k"})

	local function smoothScrollTo(scrollFrame, targetY, duration)
		if not scrollFrame or not scrollFrame.Parent then return end
		pcall(function()
			local maxY = math.max(0, scrollFrame.AbsoluteCanvasSize.Y - scrollFrame.AbsoluteSize.Y)
			targetY = math.clamp(tonumber(targetY) or 0, 0, maxY)
			local current = scrollFrame.CanvasPosition
			if math.abs(current.Y - targetY) <= 1 then
				scrollFrame.CanvasPosition = Vector2.new(current.X, targetY)
				return
			end

			local oldTween = activeSearchScrollTweens[scrollFrame]
			if oldTween then
				pcall(function() oldTween:Cancel() end)
			end

			local tween = TweenService:Create(
				scrollFrame,
				TweenInfo.new(duration or 0.32, Enum.EasingStyle.Quint, Enum.EasingDirection.Out),
				{CanvasPosition = Vector2.new(current.X, targetY)}
			)
			activeSearchScrollTweens[scrollFrame] = tween
			tween.Completed:Connect(function()
				if activeSearchScrollTweens[scrollFrame] == tween then
					activeSearchScrollTweens[scrollFrame] = nil
				end
			end)
			tween:Play()
		end)
	end

	local function scrollSearchResultIntoView(frame)
		if not frame or not frame.Parent then return end
		local scrollFrame = getParentScrollingFrame(frame)
		if not scrollFrame then return end

		pcall(function()
			local relativeY = frame.AbsolutePosition.Y - scrollFrame.AbsolutePosition.Y
			local targetY = scrollFrame.CanvasPosition.Y + relativeY - 10
			smoothScrollTo(scrollFrame, targetY, 0.34)
		end)
	end

	local function pulseSearchResultFrame(frame)
		if not frame or not frame.Parent or not frame:IsA("GuiObject") then return end

		pcall(function()
			local oldStroke = frame:FindFirstChild("SearchResultFocusStroke")
			if oldStroke then
				oldStroke:Destroy()
			end

			local focusStroke = Create("UIStroke", frame, {
				Name = "SearchResultFocusStroke",
				Color = Theme["Color Theme"],
				Thickness = 1.4,
				Transparency = 1,
				ApplyStrokeMode = Enum.ApplyStrokeMode.Border
			})

			CreateTween({focusStroke, "Transparency", 0.05, 0.12})
			CreateTween({focusStroke, "Thickness", 2.2, 0.16})

			task.delay(0.42, function()
				if focusStroke and focusStroke.Parent then
					local fade = TweenService:Create(
						focusStroke,
						TweenInfo.new(0.28, Enum.EasingStyle.Quad, Enum.EasingDirection.Out),
						{Transparency = 1, Thickness = 1}
					)
					fade:Play()
					fade.Completed:Connect(function()
						if focusStroke and focusStroke.Parent then
							focusStroke:Destroy()
						end
					end)
				end
			end)
		end)
	end

	local function focusSearchResultElement(elem)
		if not elem then return end

		pcall(function()
			if elem.Tab then
				elem.Tab:Enable()
			end
		end)

		task.delay(0.08, function()
			pcall(function()
				if elem.Frame and elem.Frame.Parent then
					scrollSearchResultIntoView(elem.Frame)
					pulseSearchResultFrame(elem.Frame)
				end
			end)
		end)
	end

	local function applyActiveTabSearchFilter()
		local query = SearchInput.Text or ""
		
		local activeTabInfo = nil
		for _, tInfo in ipairs(splib.Tabs) do
			if tInfo.func and tInfo.func.Enabled == true then
				activeTabInfo = tInfo
				break
			end
		end
		if not activeTabInfo then return end

		local container = activeTabInfo.Cont
		if not container then return end

		if not originalElementVisibilities[container] then
			local items = {}
			for _, child in ipairs(container:GetChildren()) do
				if child:IsA("GuiObject") then
					items[child] = child.Visible
				end
			end
			originalElementVisibilities[container] = items
		end

		if (string.lower(query):match("^%s*(.-)%s*$") or "") == "" then
			for child, originalVisible in pairs(originalElementVisibilities[container] or {}) do
				pcall(function()
					child.Visible = originalVisible
				end)
			end
			return
		end

		local visibleFrames = {}
		local visibleSections = {}
		local matchedSections = {}

		for _, elem in ipairs(splib.SearchElements) do
			if elem.Frame and elem.Tab == activeTabInfo.func and searchElementMatches(elem, query) then
				visibleFrames[elem.Frame] = true
				if elem.Type == "Section" then
					matchedSections[elem.Frame] = true
					visibleSections[elem.Frame] = true
				elseif elem.SectionFrame then
					visibleSections[elem.SectionFrame] = true
				end
			end
		end

		for _, elem in ipairs(splib.SearchElements) do
			if elem.Frame and elem.Tab == activeTabInfo.func and elem.SectionFrame and matchedSections[elem.SectionFrame] then
				visibleFrames[elem.Frame] = true
				visibleSections[elem.SectionFrame] = true
			end
		end

		for _, child in ipairs(container:GetChildren()) do
			if child:IsA("GuiObject") then
				child.Visible = visibleFrames[child] == true or visibleSections[child] == true
			end
		end
	end
	local function clearSearchFilter()
		SearchInput.Text = ""
		SearchResultsDropdown.Visible = false
		for _, item in ipairs(SearchResultsDropdown:GetChildren()) do
			if item:IsA("GuiButton") then item:Destroy() end
		end
		
		for container, items in pairs(originalElementVisibilities) do
			for child, originalVisible in pairs(items) do
				pcall(function()
					child.Visible = originalVisible
				end)
			end
		end
		table.clear(originalElementVisibilities)

		for _, tabInfo in ipairs(splib.Tabs) do
			pcall(function()
				if tabInfo.TabButton then
					tabInfo.TabButton.Visible = true
				end
			end)
		end
	end

	local function getSearchSidebarOffset()
		local offset = 0
		pcall(function()
			if ControlSize2 then
				offset = ControlSize2.Position.X.Offset
			end
		end)
		if offset <= 0 then
			offset = getSearchSidebarWidth()
		end
		return offset
	end

	local function expandSidebarForSearch()
		if not ControlSize2 or type(tweenControlSizeX) ~= "function" then
			return false
		end

		local currentX = getSearchSidebarOffset()
		local targetX = math.min(expandedSizeX or currentX, 100)

		if currentX >= targetX - 1 then
			return false
		end

		if not searchSavedSidebarX then
			searchSavedSidebarX = currentX
		end

		searchExpandBusy = true
		tweenControlSizeX(targetX, 0.18)
		task.delay(0.2, function()
			searchExpandBusy = false
			if isSearchOpen then
				updateSearchLayout(false)
			end
		end)
		return true
	end

	local function restoreSidebarAfterSearch()
		if not ControlSize2 or type(tweenControlSizeX) ~= "function" then
			searchSavedSidebarX = nil
			return
		end

		local restoreX = searchSavedSidebarX
		searchSavedSidebarX = nil
		if not restoreX then
			return
		end

		if math.abs(getSearchSidebarOffset() - restoreX) > 1 then
			tweenControlSizeX(restoreX, 0.18)
		end
	end


	SearchInput:GetPropertyChangedSignal("Text"):Connect(function()
		local query = SearchInput.Text or ""
		
		for _, item in ipairs(SearchResultsDropdown:GetChildren()) do
			if item:IsA("GuiButton") then item:Destroy() end
		end

		if (string.lower(query):match("^%s*(.-)%s*$") or "") == "" then
			SearchResultsDropdown.Visible = false
			clearSearchFilter()
			return
		end

		local matches = {}
		for _, elem in ipairs(splib.SearchElements) do
			if elem.Frame and elem.Frame.Parent then
				if searchElementMatches(elem, query) then
					table.insert(matches, elem)
				end
			end
		end

		local tabsWithMatches = {}
		for _, elem in ipairs(matches) do
			if elem.Tab then
				tabsWithMatches[elem.Tab] = true
			end
		end

		for _, tabInfo in ipairs(splib.Tabs) do
			pcall(function()
				if tabInfo.TabButton then
					tabInfo.TabButton.Visible = tabsWithMatches[tabInfo.func] == true
				end
			end)
		end

		local success, err = pcall(applyActiveTabSearchFilter)
		if not success then
			warn("SP Library Search Error: " .. tostring(err))
		end

		if #matches == 0 then
			SearchResultsDropdown.Visible = false
			return
		end

		SearchResultsDropdown.Visible = true
		local itemHeight = 20
		local dropdownPadding = 10
		local maxDropdownHeight = 150
		local targetHeight = math.min(#matches * itemHeight + dropdownPadding, maxDropdownHeight)
		updateSearchLayout(false)
		SearchResultsDropdown.Size = UDim2.new(0, getSearchDropdownWidth(), 0, targetHeight)

		for _, elem in ipairs(matches) do
			local tabName = "Unknown Tab"
			for _, tInfo in ipairs(splib.Tabs) do
				if tInfo.func == elem.Tab then
					tabName = tInfo.TabInfo.Name
					break
				end
			end

			local optionHint = ""
			local matchedOptions = getMatchedSearchOptions(elem, query, 2)
			local primaryMatchedOption = matchedOptions[1]
			if #matchedOptions > 0 and not isGeneralMatch(elem.Name, query) then
				local shownOptions = {}
				for _, optionName in ipairs(matchedOptions) do
					table.insert(shownOptions, escapeRichText(optionName))
				end
				optionHint = string.format(" <font color=\"#808080\" size=\"8\">  Option: %s</font>", table.concat(shownOptions, ", "))
			end

			local btn = Create("TextButton", SearchResultsDropdown, {
				Size = UDim2.new(1, 0, 0, itemHeight),
				BackgroundTransparency = 1,
				RichText = true,
				Text = string.format("  %s%s <font color=\"#808080\" size=\"8\">  %s</font>", escapeRichText(elem.Name), optionHint, (elem.Type == "Section" and "Section in " or "in ") .. escapeRichText(tabName)),
				TextColor3 = Theme["Color Text"],
				Font = Enum.Font.GothamMedium,
				TextSize = 10,
				TextXAlignment = Enum.TextXAlignment.Left,
				TextTruncate = Enum.TextTruncate.AtEnd,
				ZIndex = 101,
				AutoButtonColor = false
			})
			Make("Corner", btn, UDim.new(0, 4))

			btn.MouseEnter:Connect(function()
				btn.BackgroundTransparency = 0.85
				btn.BackgroundColor3 = Theme["Color Stroke"]
			end)
			btn.MouseLeave:Connect(function()
				btn.BackgroundTransparency = 1
			end)
			
			btn.Activated:Connect(function()
				focusSearchResultElement(elem)

				local success, err = pcall(applyActiveTabSearchFilter)
				if not success then
					warn("SP Library Search Error: " .. tostring(err))
				end

				SearchResultsDropdown.Visible = false
				SearchInput:ReleaseFocus()

				if primaryMatchedOption and type(elem.SearchAction) == "function" then
					task.defer(function()
						pcall(elem.SearchAction, primaryMatchedOption, query)
					end)
				end
			end)
		end
	end)


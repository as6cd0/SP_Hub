        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            ignoreBindClickUntil = tick() + 0.25
        end
    end)

    local function updateDisplay()
        local nm = (typeof(state.Value) == "EnumItem" and state.Value.Name) or tostring(state.Value)
        BindBox.Text = nm
        BindBox.TextColor3 = state.Disabled and Theme["Color Dark Text"] or Theme["Color Text"]
        BindBox.TextTransparency = state.Disabled and 0.35 or 0
    end

    local function setDisabled(disabled, skipSave)
        state.Disabled = disabled and true or false
        if state.Disabled and Holding then
            Holding = false
            task.spawn(Callback, false)
        end

        if state.Disabled then
            DisableCheck.Visible = true
            DisableCheck.Rotation = -20
            DisableCheck.Size = UDim2.new(0, 0, 0, 0)
            DisableCheck.TextTransparency = 1
            CreateTween({DisableFill, "Size", UDim2.new(1, -6, 1, -6), 0.16})
            CreateTween({DisableCheck, "Size", UDim2.new(1, -2, 1, -2), 0.16})
            CreateTween({DisableCheck, "Rotation", 0, 0.16})
            CreateTween({DisableCheck, "TextTransparency", 0, 0.12})
        else
            CreateTween({DisableFill, "Size", UDim2.new(0, 0, 0, 0), 0.16})
            CreateTween({DisableCheck, "Size", UDim2.new(0, 0, 0, 0), 0.12})
            CreateTween({DisableCheck, "Rotation", 18, 0.12})
            CreateTween({DisableCheck, "TextTransparency", 1, 0.1})
            task.delay(0.13, function()
                if not state.Disabled and DisableCheck and DisableCheck.Parent then
                    DisableCheck.Visible = false
                    DisableCheck.Rotation = 0
                end
            end)
        end

        CreateTween({BindBox, "TextTransparency", state.Disabled and 0.35 or 0, 0.16})
        BindBox.TextColor3 = state.Disabled and Theme["Color Dark Text"] or Theme["Color Text"]

        if Flag and not skipSave then
            local keyName = (typeof(state.Value) == "EnumItem" and state.Value.Name) or tostring(state.Value)
            SaveBindFlag(BindSaveKey, keyName, state.Disabled)
        end
    end

    updateDisplay()
    setDisabled(state.Disabled, true)

    themeConnection = Connection.ThemeChanged:Connect(function()
        task.defer(function()
            if isDestroyed then return end
            BindBox.BackgroundColor3 = Theme["Color Stroke"]
            DisableBox.BackgroundColor3 = Theme["Color Stroke"]
            updateDisplay()
        end)
    end)

    DisableBox.Activated:Connect(function()
        ignoreBindClickUntil = tick() + 0.25
        setDisabled(not state.Disabled)
    end)

    Frame.Activated:Connect(function()
        if isDestroyed or tick() < ignoreBindClickUntil then return end

        if Configs and Configs.PremiumOnly and not splib.IsPremium then
            splib:MakeNotification{
                Name = "Premium Only",
                Image = "rbxassetid://10734966248",
                Content = "This feature is for Premium users",
                Time = 1.5
            }
            return
        end

        if state.Binding then return end
        state.Binding = true
        BindBox.Text = "..."
        BindBox.TextColor3 = Theme["Color Text"]
        BindBox.TextTransparency = 0

        if bindingConnection and bindingConnection.Connected then
            bindingConnection:Disconnect()
        end

        bindingConnection = UserInputService.InputBegan:Connect(function(input, gp)
            if not state.Binding or isDestroyed then return end

            if input.UserInputType ~= Enum.UserInputType.Keyboard then
                BindBox.Text = "Invalid"
                task.wait(0.5)
                updateDisplay()
                state.Binding = false
                if bindingConnection and bindingConnection.Connected then
                    bindingConnection:Disconnect()
                end
                bindingConnection = nil
                return
            end

            local newKey
            if input.KeyCode and input.KeyCode ~= Enum.KeyCode.Unknown then
                newKey = input.KeyCode
            end

            if newKey then
                state.Value = newKey
                updateDisplay()

                if Flag then
                    SaveBindFlag(BindSaveKey, newKey.Name, state.Disabled)
                    splib.Flags[Flag] = state
                end
                if state.Save then SaveCfg(game.GameId) end
            end

            state.Binding = false
            if bindingConnection and bindingConnection.Connected then
                bindingConnection:Disconnect()
            end
            bindingConnection = nil
        end)
    end)

    local objBind = {}

    function objBind:_HandleInputBegan(input, gp)
        if isDestroyed or state.Binding or state.Disabled or isTextInputFocused() then return end

        local match = false
        if typeof(state.Value) == "EnumItem" then
            if input.KeyCode == state.Value then
                match = true
            elseif input.UserInputType == state.Value then
                match = true
            end
        end

        if match then
            if Configs and Configs.PremiumOnly and not splib.IsPremium then
                splib:MakeNotification{
                    Name = "Premium Only",
                    Image = "rbxassetid://10734966248",
                    Content = "This feature is for Premium users",
                    Time = 1.5
                }
                return
            end

            if state.Hold then
                Holding = true
                task.spawn(Callback, Holding)
            else
                task.spawn(Callback)
            end
        end
    end

    function objBind:_HandleInputEnded(input, gp)
        if isDestroyed or state.Disabled then return end
        if state.Hold and Holding and input.KeyCode == state.Value then
            Holding = false
            task.spawn(Callback, Holding)
        end
    end

    function objBind:Get() return state.Value end
    function objBind:GetDisabled() return state.Disabled end
    function objBind:SetDisabled(val) setDisabled(val) end
    function objBind:Visible(val) Funcs:ToggleVisible(Frame, val) end
    function objBind:Destroy()
        isDestroyed = true
        state.Binding = false
        state.Value = Enum.KeyCode.Unknown
        if bindingConnection and bindingConnection.Connected then bindingConnection:Disconnect() end
        if themeConnection and themeConnection.Connected then themeConnection:Disconnect() end
        local index = table.find(Binds, objBind)
        if index then table.remove(Binds, index) end
        Frame:Destroy()
    end
    function objBind:Callback(fn)
        if type(fn) == "function" then Callback = fn end
    end
    function objBind:Set(val)
        if typeof(val) == "EnumItem" or type(val) == "number" then
            state.Value = val
            updateDisplay()
        elseif type(val) == "boolean" then
            setDisabled(val)
        end
    end

    bindContextMenu(Frame, function()
        local keyName = (typeof(state.Value) == "EnumItem" and state.Value.Name) or tostring(state.Value)
        return {
            makeCopyItem(function() return joinContextLines(Name, Desc, "Key: " .. keyName, "Disabled: " .. boolText(state.Disabled)) end, "Bind copied", "Copy"),
            {
                Text = state.Disabled and "Enable Bind" or "Disable Bind",
                Callback = function()
                    setDisabled(not state.Disabled)
                    notifyContextAction("Bind", (state.Disabled and "Disabled" or "Enabled") .. ": " .. Name)
                end
            },
            makeBackToDefaultItem(function()
                return {Key = OriginalBindDefault, Disabled = OriginalBindDisabled}
            end, function(value)
                if type(value) == "table" then
                    state.Value = value.Key or Enum.KeyCode.Unknown
                    updateDisplay()
                    setDisabled(value.Disabled == true)
                    if Flag then
                        local resetKeyName = (typeof(state.Value) == "EnumItem" and state.Value.Name) or tostring(state.Value)
                        SaveBindFlag(BindSaveKey, resetKeyName, state.Disabled)
                    end
                end
            end)
        }
    end)

    if Flag then
        splib.Flags[Flag] = state
        if BindSaveKey then
            splib.Flags[BindSaveKey] = state
        end
    end
    table.insert(Binds, objBind)

    registerSearchElement(self, Name, Frame, getCurrentSearchSection(self, container))
    return objBind
end
function splib:ClearAllBinds()
    for _, bind in ipairs(Binds) do
        if bind.Set then
            bind:Set(Enum.KeyCode.Unknown)
        end
    end
end


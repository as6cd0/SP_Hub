	local function normalizeSearchText(text)
		text = tostring(text or ""):lower()
		text = text:gsub("%s+", " ")
		text = text:gsub("^%s+", ""):gsub("%s+$", "")
		return text
	end

	local function isSmartMatch(optionName, query)
		local normOption = normalizeSearchText(optionName)
		local normQuery = normalizeSearchText(query)

		if normQuery == "" then
			return true
		end

		if normOption:find(normQuery, 1, true) then
			return true
		end

		local compactOption = normOption:gsub("%s+", "")
		local compactQuery = normQuery:gsub("%s+", "")
		if compactOption:find(compactQuery, 1, true) then
			return true
		end

		local hasTokens = false
		for token in normQuery:gmatch("%S+") do
			hasTokens = true
			if not normOption:find(token, 1, true) and not compactOption:find(token, 1, true) then
				return false
			end
		end

		return hasTokens
	end


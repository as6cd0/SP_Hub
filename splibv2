local function rememberTranslationAlias(key, text)
    if key == nil or text == nil then return end
    local map = getTranslationMap()
    key = tostring(key)
    text = tostring(text)
    if key == "" or text == "" then return end
    map[key] = key
    map[text] = key
end

local function resolveTranslationKey(text)
    if text == nil then return nil end
    local map = getTranslationMap()
    return map[tostring(text)]

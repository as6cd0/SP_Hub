local function fadeVisualTree(root, delayTime, duration, maxInstances)
    if not root or not root.Parent then return end

    delayTime = tonumber(delayTime) or 0
    duration = tonumber(duration) or 0.22
    maxInstances = tonumber(maxInstances) or 80

    local entries = {}
    local count = 0

    local function addEntry(instance, prop)
        if count >= maxInstances then return end
        local ok, originalValue = pcall(function()
            return instance[prop]
        end)
        if ok and type(originalValue) == "number" and originalValue < 1 then
            count += 1
            table.insert(entries, {
                Instance = instance,
                Prop = prop,
                Original = originalValue
            })
        end
    end

    local function scan(instance)
        if count >= maxInstances then return end

        if instance:IsA("GuiObject") then
            if instance.Visible == false then return end
            addEntry(instance, "BackgroundTransparency")

            if instance:IsA("TextLabel") or instance:IsA("TextButton") or instance:IsA("TextBox") then
                addEntry(instance, "TextTransparency")
            end

            if instance:IsA("ImageLabel") or instance:IsA("ImageButton") then
                addEntry(instance, "ImageTransparency")
            end
        elseif instance:IsA("UIStroke") then
            addEntry(instance, "Transparency")
        end

        for _, child in ipairs(instance:GetChildren()) do
            scan(child)
            if count >= maxInstances then break end
        end
    end

    scan(root)

    for _, entry in ipairs(entries) do
        pcall(function()
            entry.Instance[entry.Prop] = 1
        end)
    end

    task.delay(delayTime, function()
        local tweenInfo = TweenInfo.new(duration, Enum.EasingStyle.Quint, Enum.EasingDirection.Out)
        for _, entry in ipairs(entries) do
            pcall(function()
                if entry.Instance and entry.Instance.Parent then
                    tweenPropertySafe(entry.Instance, tweenInfo, {
                        [entry.Prop] = entry.Original
                    })
                end
            end)
        end
    end)
end

local function animateDirectChildrenBuild(container, startDelay, stepDelay, maxChildren)
    if not container or not container.Parent then return end

    startDelay = tonumber(startDelay) or 0
    stepDelay = tonumber(stepDelay) or 0.025
    maxChildren = tonumber(maxChildren) or 28

    local children = {}
    for _, child in ipairs(container:GetChildren()) do
        if child:IsA("GuiObject") and child.Visible then
            table.insert(children, child)
        end
    end

    table.sort(children, function(a, b)
        if a.LayoutOrder == b.LayoutOrder then
            return a.AbsolutePosition.Y < b.AbsolutePosition.Y
        end
        return a.LayoutOrder < b.LayoutOrder
    end)

    for index, child in ipairs(children) do
        if index > maxChildren then break end
        fadeVisualTree(child, startDelay + ((index - 1) * stepDelay), 0.2, 45)
    end
end


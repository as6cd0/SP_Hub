        splib.Flags[Flag].Object = Toggle
        splib.Flags[Flag].Get = function()
            return Default
        end
        splib.Flags[Flag].Set = function(selfOrValue, maybeValue)
            local value = maybeValue
            if type(selfOrValue) == "boolean" or maybeValue == nil then
                value = selfOrValue
            end
            Toggle:Set(value == true, {internal = true})
        end
    end


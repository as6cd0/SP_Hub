local function isMouseInside(guiObject)
	local inside = false
	pcall(function()
		if guiObject and guiObject.Parent and guiObject.AbsolutePosition and guiObject.AbsoluteSize then
			local mousePos = UserInputService:GetMouseLocation()
			local inset = game:GetService("GuiService"):GetGuiInset()
			local mouseX, mouseY = mousePos.X, mousePos.Y
			local ap = guiObject.AbsolutePosition
			local as = guiObject.AbsoluteSize
			
			local realMouseX = mouseX
			local realMouseY = mouseY
			local ignoreInset = false
			if ScreenGui then
				ignoreInset = ScreenGui.IgnoreGuiInset
			end
			if not ignoreInset then
				realMouseY = realMouseY - inset.Y
				realMouseX = realMouseX - inset.X
			end
			
			inside = realMouseX >= ap.X and realMouseX <= (ap.X + as.X) and realMouseY >= ap.Y and realMouseY <= (ap.Y + as.Y)
		end
	end)
	return inside
end

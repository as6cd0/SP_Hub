local function getLiveTranslation(key)
    key = tostring(key or "")
    local translator = rawget(_G, "SP_Hub_Translator")
    if type(translator) == "function" then
        local ok, result = pcall(translator, key)
        if ok and result ~= nil then
            local translated = tostring(result)
            rememberTranslationAlias(key, translated)
            return translated
        end
    end
    rememberTranslationAlias(key, key)
    return key
end

local function isTranslatableTextObject(obj)
    return obj
        and typeof(obj) == "Instance"
        and (obj:IsA("TextLabel") or obj:IsA("TextButton") or obj:IsA("TextBox"))
end

local function isAnimatedTextProperty(obj, property)
    return property == "Text" and isTranslatableTextObject(obj)
end

local function getTextPropertyValue(obj, property)
    if not (obj and typeof(obj) == "Instance") then return "" end
    property = property or "Text"
    local ok, value = pcall(function()
        return obj[property]
    end)
    if ok and value ~= nil then
        return tostring(value)
    end
    return ""
end

local function setTextPropertyValue(obj, property, value)
    if not (obj and typeof(obj) == "Instance") then return end
    property = property or "Text"
    pcall(function()
        obj[property] = tostring(value or "")
    end)
end

splib.TranslationAnimation = splib.TranslationAnimation or {
    Enabled = true,
    Mode = "Build",
    Duration = 0.34,
    FadeOutTime = 0.08,
    Stagger = 0.010,
    MaxDelay = 0.24,
    BuildSteps = 12,
    MinStepWait = 0.010,
    MaxStepWait = 0.035,
    TextFadeAmount = 0.62
}

function splib:SetTranslationAnimation(config)
    if type(config) ~= "table" then return end
    self.TranslationAnimation = self.TranslationAnimation or {}
    for key, value in pairs(config) do
        self.TranslationAnimation[key] = value
    end
end

local function applyTranslationText(label, newText, refreshCallback, property)
    if not isTranslatableTextObject(label) then return end
    setTextPropertyValue(label, property or "Text", newText)
    if type(refreshCallback) == "function" then
        task.defer(refreshCallback)
    end
end

local function getTranslationAnimationConfig()
    local cfg = splib.TranslationAnimation
    if type(cfg) ~= "table" then
        cfg = {}
        splib.TranslationAnimation = cfg
    end
    return cfg
end

local function splitTextGraphemes(text)
    text = tostring(text or "")
    local chars = {}

    local ok = pcall(function()
        for first, last in utf8.graphemes(text) do
            table.insert(chars, text:sub(first, last))
        end
    end)

    if ok and #chars > 0 then
        return chars
    end

    for i = 1, #text do
        chars[#chars + 1] = text:sub(i, i)
    end
    return chars
end

local function joinTextGraphemes(chars, count)
    count = math.clamp(tonumber(count) or 0, 0, #chars)
    if count <= 0 then return "" end
    local out = table.create and table.create(count) or {}
    for i = 1, count do
        out[i] = chars[i]
    end
    return table.concat(out)
end

local function animateTranslationLabel(label, newText, refreshCallback, delayTime, property)
    property = property or "Text"
    newText = tostring(newText or "")
    if not isTranslatableTextObject(label) then return end

    if not isAnimatedTextProperty(label, property) then
        applyTranslationText(label, newText, refreshCallback, property)
        return
    end

    local currentText = getTextPropertyValue(label, property)
    local cfg = getTranslationAnimationConfig()
    if cfg.Enabled == false or currentText == newText then
        applyTranslationText(label, newText, refreshCallback, property)
        return
    end

    local abs = label.AbsoluteSize
    if not label.Visible or abs.X <= 2 or abs.Y <= 2 then
        applyTranslationText(label, newText, refreshCallback, property)
        return
    end

    delayTime = tonumber(delayTime) or 0
    local duration = tonumber(cfg.Duration) or 0.34
    local fadeOutTime = tonumber(cfg.FadeOutTime) or 0.08
    local textFadeAmount = tonumber(cfg.TextFadeAmount) or 0.62
    local buildSteps = math.max(1, math.floor(tonumber(cfg.BuildSteps) or 12))
    local minStepWait = tonumber(cfg.MinStepWait) or 0.010
    local maxStepWait = tonumber(cfg.MaxStepWait) or 0.035

    task.delay(delayTime, function()
        if not (label and label.Parent) then return end

        pcall(function()
            local oldSweep = label:FindFirstChild("SPTranslateSweep")
            if oldSweep then oldSweep:Destroy() end
        end)

        local token = tostring(os.clock()) .. ":" .. tostring(math.random(1, 999999))
        pcall(function() label:SetAttribute("SPTranslateToken", token) end)

        local oldTextTransparency = 0
        local oldStrokeTransparency = nil
        pcall(function()
            oldTextTransparency = label.TextTransparency
            oldStrokeTransparency = label.TextStrokeTransparency
        end)

        local fadedTransparency = math.clamp(oldTextTransparency + textFadeAmount, 0, 1)

        pcall(function()
            TweenService:Create(
                label,
                TweenInfo.new(math.max(0.02, fadeOutTime), Enum.EasingStyle.Quad, Enum.EasingDirection.Out),
                { TextTransparency = fadedTransparency }
            ):Play()
        end)

        task.wait(math.max(0.02, fadeOutTime))
        if not (label and label.Parent) then return end

        local stillSameToken = true
        pcall(function()
            stillSameToken = label:GetAttribute("SPTranslateToken") == token
        end)
        if not stillSameToken then return end

        local chars = splitTextGraphemes(newText)
        local total = #chars

        if total <= 0 then
            setTextPropertyValue(label, property, "")
            pcall(function() label.TextTransparency = oldTextTransparency end)
            if oldStrokeTransparency ~= nil then
                pcall(function() label.TextStrokeTransparency = oldStrokeTransparency end)
            end
            if type(refreshCallback) == "function" then
                task.defer(refreshCallback)
            end
            return
        end

        local steps = math.clamp(math.min(buildSteps, total), 1, 18)
        local revealTime = math.max(0.06, duration - fadeOutTime)
        local stepWait = math.clamp(revealTime / steps, minStepWait, maxStepWait)

        setTextPropertyValue(label, property, "")
        pcall(function()
            TweenService:Create(
                label,
                TweenInfo.new(revealTime, Enum.EasingStyle.Quint, Enum.EasingDirection.Out),
                { TextTransparency = oldTextTransparency }
            ):Play()
        end)

        for step = 1, steps do
            if not (label and label.Parent) then return end
            local sameToken = true
            pcall(function()
                sameToken = label:GetAttribute("SPTranslateToken") == token
            end)
            if not sameToken then return end

            local amount = math.ceil((total * step) / steps)
            setTextPropertyValue(label, property, joinTextGraphemes(chars, amount))
            task.wait(stepWait)
        end

        if not (label and label.Parent) then return end
        setTextPropertyValue(label, property, newText)
        pcall(function() label.TextTransparency = oldTextTransparency end)
        if oldStrokeTransparency ~= nil then
            pcall(function() label.TextStrokeTransparency = oldStrokeTransparency end)
        end

        if type(refreshCallback) == "function" then
            task.defer(refreshCallback)
        end
    end)
end

function splib:RegisterTranslationObject(instance, property, sourceText, refreshCallback)
    if not isTranslatableTextObject(instance) then return end
    property = property or "Text"

    local currentText = getTextPropertyValue(instance, property)
    local item = self._TranslationIndex[instance]
    local key = resolveTranslationKey(sourceText or currentText)

    if not item then
        item = { Instance = instance, Properties = {} }
        self._TranslationIndex[instance] = item
        table.insert(self._TranslationItems, item)
    end

    local propItem = item.Properties[property]
    if not propItem then
        propItem = {}
        item.Properties[property] = propItem
    end

    if not key then
        if propItem.Key and type(sourceText) == "string" then
            local translated = getLiveTranslation(propItem.Key)
            if translated ~= "" and sourceText:sub(1, #translated) == translated then
                propItem.Suffix = sourceText:sub(#translated + 1)
                propItem.Refresh = refreshCallback or propItem.Refresh
            end
        end
        return
    end

    local translatedNow = getLiveTranslation(key)
    local suffix = ""
    if currentText ~= "" and translatedNow ~= "" and currentText:sub(1, #translatedNow) == translatedNow then
        suffix = currentText:sub(#translatedNow + 1)
    elseif sourceText and translatedNow ~= "" then
        local s = tostring(sourceText)
        if s:sub(1, #translatedNow) == translatedNow then
            suffix = s:sub(#translatedNow + 1)
        end
    end

    propItem.Key = key
    propItem.Suffix = suffix
    propItem.Refresh = refreshCallback
    rememberTranslationAlias(key, currentText)
end

function splib:RegisterTranslationLabel(label, sourceText, refreshCallback)
    self:RegisterTranslationObject(label, "Text", sourceText, refreshCallback)
end

function splib:RegisterTranslationPlaceholder(textBox, sourceText, refreshCallback)
    self:RegisterTranslationObject(textBox, "PlaceholderText", sourceText, refreshCallback)
end

function splib:RefreshTranslations(options)
    local animate = true
    if type(options) == "table" and options.Animate == false then
        animate = false
    end

    local operations = {}
    local seen = setmetatable({}, {__mode = "k"})

    local function isSeen(instance, property)
        local props = seen[instance]
        if not props then
            props = {}
            seen[instance] = props
        end
        if props[property] then
            return true
        end
        props[property] = true
        return false
    end

    local function queue(instance, property, key, suffix, refreshCallback)
        if not isTranslatableTextObject(instance) then return end
        property = property or "Text"
        if isSeen(instance, property) then return end
        if type(key) ~= "string" or key == "" then return end

        local translated = getLiveTranslation(key) .. tostring(suffix or "")
        local currentText = getTextPropertyValue(instance, property)

        if currentText == translated then
            if type(refreshCallback) == "function" then
                task.defer(refreshCallback)
            end
            return
        end

        table.insert(operations, {
            Instance = instance,
            Property = property,
            Text = translated,
            Refresh = refreshCallback
        })
    end

    local items = self._TranslationItems
    if type(items) == "table" then
        for i = #items, 1, -1 do
            local item = items[i]
            local instance = item and (item.Instance or item.Label)
            if not (instance and typeof(instance) == "Instance" and instance.Parent) then
                if instance then
                    self._TranslationIndex[instance] = nil
                end
                table.remove(items, i)
            else
                if item.Properties then
                    for property, propItem in pairs(item.Properties) do
                        queue(instance, property, propItem.Key, propItem.Suffix, propItem.Refresh)
                    end
                elseif item.Key then
                    queue(instance, "Text", item.Key, item.Suffix, item.Refresh)
                end
            end
        end
    end

    pcall(function()
        if ScreenGui and ScreenGui.Parent then
            local function addFromObject(obj)
                if not isTranslatableTextObject(obj) then return end

                if obj:IsA("TextLabel") or obj:IsA("TextButton") then
                    local currentText = getTextPropertyValue(obj, "Text")
                    if currentText ~= "" then
                        local key = resolveTranslationKey(currentText)
                        if key then
                            queue(obj, "Text", key, "", nil)
                        end
                    end
                end

                if obj:IsA("TextBox") then
                    local placeholder = getTextPropertyValue(obj, "PlaceholderText")
                    if placeholder ~= "" then
                        local placeholderKey = resolveTranslationKey(placeholder)
                        if placeholderKey then
                            queue(obj, "PlaceholderText", placeholderKey, "", nil)
                        end
                    end

                    local shouldTranslateText = false
                    pcall(function()
                        shouldTranslateText = obj:GetAttribute("SPTranslateText") == true
                    end)
                    if shouldTranslateText then
                        local currentInputText = getTextPropertyValue(obj, "Text")
                        if currentInputText ~= "" then
                            local inputKey = resolveTranslationKey(currentInputText)
                            if inputKey then
                                queue(obj, "Text", inputKey, "", nil)
                            end
                        end
                    end
                end
            end

            addFromObject(ScreenGui)
            for _, obj in ipairs(ScreenGui:GetDescendants()) do
                addFromObject(obj)
            end
        end
    end)

    local cfg = getTranslationAnimationConfig()
    local stagger = tonumber(cfg.Stagger) or 0.012
    local maxDelay = tonumber(cfg.MaxDelay) or 0.28

    for index, op in ipairs(operations) do
        local delayTime = math.min((index - 1) * stagger, maxDelay)
        if animate then
            animateTranslationLabel(op.Instance, op.Text, op.Refresh, delayTime, op.Property)
        else
            applyTranslationText(op.Instance, op.Text, op.Refresh, op.Property)
        end
    end
end

local function ButtonFrame(parent, Title, Description, HolderSize, isBind)

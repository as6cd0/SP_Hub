local BindsFile = "binds.json"
local function GetBindSaveKey(flag, configs)
    if not flag then
        return nil, nil
    end

    local base = tostring(flag)
    local explicitId = configs.BindId or configs.BindID or configs.Id or configs.ID or configs.SaveId or configs.SaveID or configs.SaveKey
    if explicitId ~= nil then
        return base .. "::" .. tostring(explicitId), explicitId
    end

    BindSaveKeyCounts[base] = (BindSaveKeyCounts[base] or 0) + 1
    local index = BindSaveKeyCounts[base]
    return base .. "::" .. tostring(index), index
end

local function normalizeBindRecord(record)
    if type(record) == "table" then
        return record.Key or record.KeyName or record.key or record[1], record.Disabled
    elseif type(record) == "string" then
        return record, nil
    end
    return nil, nil
end

local function SaveBindFlag(flag, keyName, disabled)
    local data = safeReadJsonFile(BindsFile, {}) or {}
    local oldKey, oldDisabled = normalizeBindRecord(data[flag])

    keyName = keyName or oldKey or "Unknown"
    if disabled == nil then
        disabled = oldDisabled == true
    end

    data[flag] = {
        Key = keyName,
        Disabled = disabled and true or false
    }
    safeWriteJsonFile(BindsFile, data)
end

local function LoadBindFlag(flag)
    local existing = safeReadJsonFile(BindsFile, nil)
    if type(existing) == "table" then
        local keyName = normalizeBindRecord(existing[flag])
        return keyName
    end
    return nil
end

local function LoadBindDisabledFlag(flag)
    local existing = safeReadJsonFile(BindsFile, nil)
    if type(existing) == "table" then
        local _, disabled = normalizeBindRecord(existing[flag])
        if disabled ~= nil then
            return disabled == true
        end
    end
    return nil
end


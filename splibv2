local function cleanupStartupBuildConnections()
    for _, conn in ipairs(startupBuildConnections) do
        pcall(function()
            if typeof(conn) == "RBXScriptConnection" and conn.Connected then
                conn:Disconnect()
            end
        end)
    end
    table.clear(startupBuildConnections)
    table.clear(startupBuildAttachedContainers)
end

local function trackStartupBuildConnection(connection)
    if typeof(connection) == "RBXScriptConnection" then
        table.insert(startupBuildConnections, connection)
    end
    return connection
end

local function animateStartupBuiltItem(guiObject, delayTime)
    if not startupBuildWatcherActive then return end
    if Minimized then return end
    if not guiObject or not guiObject.Parent or not guiObject:IsA("GuiObject") then return end
    if guiObject.Visible == false then return end

    local alreadyAnimated = false
    pcall(function()
        alreadyAnimated = guiObject:GetAttribute("SPStartupBuildAnimated") == true
    end)
    if alreadyAnimated then return end

    pcall(function()
        guiObject:SetAttribute("SPStartupBuildAnimated", true)
    end)

    delayTime = tonumber(delayTime) or 0

    fadeVisualTree(guiObject, delayTime, 0.22, 55)

    pcall(function()
        if not guiObject or not guiObject.Parent then return end
        local scale = guiObject:FindFirstChild("SPStartupBuildScale")
        if not scale then
            scale = Create("UIScale", guiObject, {
                Name = "SPStartupBuildScale",
                Scale = 0.965
            })
        else
            scale.Scale = 0.965
        end

        task.delay(delayTime, function()
            if not startupBuildWatcherActive or not guiObject or not guiObject.Parent or not scale or not scale.Parent then return end
            local tween = tweenPropertySafe(scale, TweenInfo.new(0.24, Enum.EasingStyle.Quint, Enum.EasingDirection.Out), {
                Scale = 1
            })
            task.delay(0.3, function()
                pcall(function()
                    if scale and scale.Parent and math.abs(scale.Scale - 1) < 0.02 then
                        scale:Destroy()
                    end
                end)
            end)
        end)
    end)
end

local function attachStartupBuildContainer(container, animateExisting)
    if not startupBuildWatcherActive then return end
    if not container or not container.Parent then return end
    if startupBuildAttachedContainers[container] then return end

    startupBuildAttachedContainers[container] = true

    if animateExisting then
        local existing = {}
        for _, child in ipairs(container:GetChildren()) do
            if child:IsA("GuiObject") and child.Visible then
                table.insert(existing, child)
            end
        end

        table.sort(existing, function(a, b)
            if a.LayoutOrder == b.LayoutOrder then
                return a.AbsolutePosition.Y < b.AbsolutePosition.Y
            end
            return a.LayoutOrder < b.LayoutOrder
        end)

        for index, child in ipairs(existing) do
            if index > 45 then break end
            animateStartupBuiltItem(child, 0.01 + ((index - 1) * 0.018))
        end
    end

    trackStartupBuildConnection(container.ChildAdded:Connect(function(child)
        if child and child:IsA("GuiObject") then
            task.delay(0.02, function()
                animateStartupBuiltItem(child, 0)
            end)
        end
    end))
end

local function attachStartupBuildTargets(animateExisting)
    if not startupBuildWatcherActive then return end

    pcall(function()
        if MainScroll then
            attachStartupBuildContainer(MainScroll, animateExisting)
        end
        if Containers then
            attachStartupBuildContainer(Containers, false)
            for _, child in ipairs(Containers:GetChildren()) do
                if child:IsA("GuiObject") then
                    attachStartupBuildContainer(child, animateExisting)
                end
            end
        end
        local activeContainer = getActiveBuildContainer()
        if activeContainer then
            attachStartupBuildContainer(activeContainer, animateExisting)
        end
    end)
end

local function scheduleStartupBuildAnimation()
    startupBuildAnimationQueued = false
    startupBuildAnimationPlayed = true
    startupBuildWatcherActive = false
    cleanupStartupBuildConnections()
end


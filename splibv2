local function ensureBindDispatcher()
    if bindDispatcherBegan and bindDispatcherBegan.Connected and bindDispatcherEnded and bindDispatcherEnded.Connected then
        return
    end

    if not (bindDispatcherBegan and bindDispatcherBegan.Connected) then
        bindDispatcherBegan = trackRuntimeConnection(UserInputService.InputBegan:Connect(function(input, gameProcessed)
            if isTextInputFocused() then return end
            for i = #Binds, 1, -1 do

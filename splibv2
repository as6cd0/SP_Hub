            task.delay(0.14, function()
                if b and b.Parent then
                    b:Destroy()
                end
            end)
        end)
    end

    local closeEndDelay = math.max((total - 1) * closeStepDelay + 0.16, shrinkDelay + 0.18)
    task.delay(closeEndDelay, function()
        buttons = {}
        PresetsList.Visible = false
        PresetsList.ScrollingEnabled = false
        PresetsList.CanvasPosition = Vector2.new(0, 0)
        isPresetHovered = false
        setContainerScroll(true)

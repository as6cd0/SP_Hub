function splib:GetIcon(index)
	if type(index) ~= "string" or index:find("rbxassetid://") or #index == 0 then
		return index
	end

	if index:match("^%d+$") then
		return "rbxassetid://" .. index
	end
	
	local firstMatch = nil
	index = string.lower(index):gsub("lucide", ""):gsub("-", "")
	
	if type(self.Icons) ~= "table" then
		return index
	end

	if self.Icons[index] then
	  return self.Icons[index]
	end
	
	for Name, Icon in self.Icons do
		if Name == index then
			return Icon
		elseif not firstMatch and Name:find(index, 1, true) then
			firstMatch = Icon
		end
	end
	
	return firstMatch or index
end

function splib:SetTheme(NewTheme)
	if not VerifyTheme(NewTheme) then return end
	
	splib.Save.Theme = NewTheme
	SaveJson("sp library.json", splib.Save)
	Theme = splib.Themes[NewTheme] or splib.Themes.Red or cloneDefaultTheme()
	
	Connection:FireConnection("ThemeChanged", NewTheme)
	table.foreach(splib.Instances, function(_,Val)
		local propName = GetColor(Val.Instance)
		if Val.Type == "Gradient" then
			Val.Instance.Color = Theme["Color Hub 1"] or DEFAULT_THEME_TEMPLATE["Color Hub 1"]
		elseif Val.Type == "Frame" then
			Val.Instance.BackgroundColor3 = Theme["Color Hub 2"] or DEFAULT_THEME_TEMPLATE["Color Hub 2"]
		elseif propName then
			if Val.Type == "Stroke" then
				Val.Instance[propName] = Theme["Color Stroke"] or DEFAULT_THEME_TEMPLATE["Color Stroke"]
			elseif Val.Type == "Theme" then
				Val.Instance[propName] = Theme["Color Theme"] or DEFAULT_THEME_TEMPLATE["Color Theme"]
			elseif Val.Type == "Text" then
				Val.Instance[propName] = Theme["Color Text"] or DEFAULT_THEME_TEMPLATE["Color Text"]
			elseif Val.Type == "DarkText" then
				Val.Instance[propName] = Theme["Color Dark Text"] or DEFAULT_THEME_TEMPLATE["Color Dark Text"]
			elseif Val.Type == "ScrollBar" then
				Val.Instance[propName] = Theme["Color Theme"] or DEFAULT_THEME_TEMPLATE["Color Theme"]
			end
		end
	end)
end


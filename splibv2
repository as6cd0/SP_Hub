local function getColorLuminance(color)
    return (0.299 * color.R) + (0.587 * color.G) + (0.114 * color.B)
end

local function getClosedIndicatorColor(color)
    local luminance = getColorLuminance(color)
    if luminance >= 0.75 then
        return Color3.fromRGB(20, 20, 20)
    end
    return Color3.fromRGB(255, 255, 255)
end

local function applyClosedIndicatorColor(animated)
    if isPresetOpen then
        return
    end

    local target = getClosedIndicatorColor(ColorBox.BackgroundColor3)
    if animated then
        CreateTween({Arrow, "ImageColor3", target, 0.12})
    else
        Arrow.ImageColor3 = target
    end
end

local function setColorBoxColor(newColor, withWipe)
    if typeof(newColor) ~= "Color3" then
        return
    end

    colorWipeToken = colorWipeToken + 1
    local token = colorWipeToken

    if colorWipeTween then
        pcall(function()
            colorWipeTween:Cancel()
        end)
        colorWipeTween = nil
    end

    if not withWipe then
        ColorWipe.Visible = false
        ColorWipe.Size = UDim2.new(0, 0, 1, 0)
        ColorBox.BackgroundColor3 = newColor
        applyClosedIndicatorColor(false)
        return
    end

    ColorWipe.BackgroundColor3 = newColor
    ColorWipe.Size = UDim2.new(0, 0, 1, 0)
    ColorWipe.Visible = true

    local tween = TweenService:Create(
        ColorWipe,
        TweenInfo.new(0.22, Enum.EasingStyle.Quart, Enum.EasingDirection.Out),
        {Size = UDim2.new(1, 0, 1, 0)}
    )
    colorWipeTween = tween
    tween:Play()
    tween.Completed:Connect(function()
        if token ~= colorWipeToken then
            return
        end
        ColorBox.BackgroundColor3 = newColor
        ColorWipe.Visible = false
        ColorWipe.Size = UDim2.new(0, 0, 1, 0)
        colorWipeTween = nil
        applyClosedIndicatorColor(true)
    end)
end


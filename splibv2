        TextColor3 = Theme["Color Dark Text"],
        AutomaticSize = Enum.AutomaticSize.Y,
        Size = UDim2.new(1, 0, 0, 0),
        BackgroundTransparency = 1,
        TextWrapped = true,
        TextTruncate = Enum.TextTruncate.None,
        TextSize = descTextSize,
        TextXAlignment = Enum.TextXAlignment.Left,
        TextYAlignment = Enum.TextYAlignment.Top,
        Text = Description or "",
        RichText = true,
        LayoutOrder = 2
    }), "DarkText")

    local ExtraSpacer = Create("Frame", {
        Name = "ExtraHeightSpacer",
        BackgroundTransparency = 1,
        BorderSizePixel = 0,
        Size = UDim2.new(1, 0, 0, 0),
        LayoutOrder = 99
    })

    local LabelHolder = Create("Frame", Frame, {
        Name = "LabelHolder",
        AutomaticSize = Enum.AutomaticSize.Y,
        BackgroundTransparency = 1,
        Size = getHolderSize(),
        Position = UDim2.new(0, leftPadding, 0, 0),
        AnchorPoint = Vector2.new(0, 0)
    }, {
        Create("UIListLayout", {
            SortOrder = Enum.SortOrder.LayoutOrder,
            VerticalAlignment = Enum.VerticalAlignment.Center,
            Padding = UDim.new(0, labelGap)
        }),
        Create("UIPadding", {
            PaddingTop    = UDim.new(0, verticalPadding),
            PaddingBottom = UDim.new(0, verticalPadding)
        }),
        TitleL,
        DescL,
        ExtraSpacer
    })

    local function refreshLayout()
        LabelHolder.Size = getHolderSize()

        local extraHeight = 0
        pcall(function()
            extraHeight = tonumber(Frame:GetAttribute("ExtraHeight")) or 0
        end)
        ExtraSpacer.Size = UDim2.new(1, 0, 0, math.max(0, extraHeight))

        if DescL.Visible or extraHeight > 0 then
            LabelHolder.Position = UDim2.new(0, leftPadding, 0, 0)
            LabelHolder.AnchorPoint = Vector2.new(0, 0)
        else
            LabelHolder.Position = UDim2.new(0, leftPadding, 0.5, 0)
            LabelHolder.AnchorPoint = Vector2.new(0, 0.5)
        end
    end

    pcall(function()
        Frame:GetAttributeChangedSignal("ExtraHeight"):Connect(refreshLayout)
    end)
    Frame:GetPropertyChangedSignal("AbsoluteSize"):Connect(refreshLayout)

    local bindBox
    if isBind then
        bindBox = InsertTheme(Create("TextButton", Frame, {
            Name               = "BindBox",
            Text               = "...",
            Font               = Enum.Font.GothamBold,
            TextSize           = isMobile and 12 or 14,

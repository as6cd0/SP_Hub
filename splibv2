function Tab:AddTextbox(Configs)
    local TName = Configs[1] or Configs.Name or Configs.Title or "Text Box"
    local TDesc = Configs.Desc or Configs.Description or ""
    local TDefault = Configs[2] or Configs.Default or ""
    local OriginalTextBoxDefault = TDefault
    local Flag = Configs[6] or Configs.Flag
    local TPlaceholderText = Configs[5] or Configs.PlaceholderText or "Input"
    local TClearText = Configs[3] or Configs.ClearText or false
    local Callback = Funcs:GetCallback(Configs, 4)

    if Flag then
        local isInternalSetting = (Configs.__force_container ~= nil)
        if splib.FlagsEnabled or isInternalSetting then
            local saved = LoadTextBoxFlag(Flag)
            if saved ~= nil and type(saved) == "string" then
                TDefault = saved
            end
        end
    end

    if Configs.IsMobile and not isMobile then
        return nil
    end

    if Configs.IsPC and not isPC then
        return nil
    end

    if type(TDefault) ~= "string" or TDefault:gsub(" ", ""):len() < 1 then
        TDefault = ""
    end
    if type(OriginalTextBoxDefault) ~= "string" then
        OriginalTextBoxDefault = ""
    end

    local container = Configs.__force_container or Container
    local isExpanded = false
    local inputHeight = isMobile and 18 or 20
    local isPremiumOnly = Configs and Configs.PremiumOnly == true

    local titleFont = Enum.Font.GothamMedium
    local titleTextSize = isMobile and 9 or 10
    local descFont = Enum.Font.Gotham
    local descTextSize = isMobile and 7 or 8

    local updateCollapsedSize

    local function stripRichTextForMeasure(str)
        return tostring(str or ""):gsub("<.->", "")
    end

    local function measureSingleLineWidth(str, textSize, font)
        str = stripRichTextForMeasure(str)
        if str == "" then
            return 0
        end

        local ok, size = pcall(function()
            return TextService:GetTextSize(str, textSize, font, Vector2.new(10000, 10000))
        end)

        if ok and size then
            return size.X
        end

        return #str * textSize * 0.55
    end

    local hasDescText = type(TDesc) == "string" and TDesc:match("%S") ~= nil
    local normalReservedRight = isMobile and 115 or 140

    local function getEstimatedAvailableTextWidth()
        local uiWidth = splib.Save.UISize and splib.Save.UISize[1] or 550
        local tabWidth = splib.Save.TabSize or 160
        local estimatedContainerWidth = math.max(180, (uiWidth * 0.8) - tabWidth - 20)
        return math.max(40, estimatedContainerWidth - 20 - normalReservedRight)
    end

    local function shouldStackForWidth(width)
        width = math.max(1, tonumber(width) or getEstimatedAvailableTextWidth())

        local titleWidth = measureSingleLineWidth(TName, titleTextSize, titleFont)
        local descWidth = hasDescText and measureSingleLineWidth(TDesc, descTextSize, descFont) or 0

        return isPremiumOnly
            or titleWidth > width
            or descWidth > width
    end

    local hasInputDescription = isMobile or shouldStackForWidth(getEstimatedAvailableTextWidth())
    local collapsedMaxWidth = isMobile and 104 or 126
    local textboxMinHeight = hasInputDescription and (isMobile and 24 or 20) or (isMobile and 26 or 24)

    local function getCollapsedExtraHeight()
        if hasInputDescription then
            return inputHeight + (isMobile and 6 or 4)
        else
            return 0
        end
    end

    local function getExpandedExtraHeight()
        if hasInputDescription then
            return getCollapsedExtraHeight()
        else
            return inputHeight + (isMobile and 8 or 10)
        end
    end

    local function getInputPosition()
        local offset
        if isExpanded then
            offset = (inputHeight / 2) + (isMobile and 5 or 6)
        else
            if hasInputDescription then
                offset = (inputHeight / 2) + (isMobile and 5 or 4)
            else
                offset = textboxMinHeight / 2
            end
        end
        return UDim2.new(1, -10, 1, -offset)
    end

    local textboxOptions = {
        ReservedRight = hasInputDescription and 10 or normalReservedRight,
        MinHeight = textboxMinHeight,
        MaxHeight = hasInputDescription and (isMobile and 180 or 150) or (isMobile and 92 or 56),
        VerticalPadding = 4,
        LabelGap = 1,
        TitleLineLimit = nil,
        DescLineLimit = nil
    }

    local Button, LabelFunc = ButtonFrame(container, TName, TDesc, textboxOptions)

    local function applyStackedLayout(animated)
        if hasInputDescription then return end

        hasInputDescription = true
        textboxMinHeight = isMobile and 24 or 20

        textboxOptions.ReservedRight = 10
        textboxOptions.MinHeight = textboxMinHeight
        textboxOptions.MaxHeight = nil
        textboxOptions.TitleLineLimit = nil
        textboxOptions.DescLineLimit = nil

        local TitleL = LabelFunc.TitleLabel
        local DescL = LabelFunc.DescLabel
        if TitleL then
            TitleL.TextWrapped = true
            TitleL.TextTruncate = Enum.TextTruncate.None
        end
        if DescL then
            DescL.TextWrapped = true
            DescL.TextTruncate = Enum.TextTruncate.None
        end

        if LabelFunc and type(LabelFunc.Refresh) == "function" then
            LabelFunc:Refresh()
        end

        pcall(function()
            Button:SetAttribute("ExtraHeight", getCollapsedExtraHeight())
        end)

        if updateCollapsedSize then
            updateCollapsedSize(animated == true)
        end
    end

    local function checkOverlap()
        if hasInputDescription then return end

        local frameWidth = Button.AbsoluteSize.X
        if frameWidth <= 0 then return end

        local availableTextWidth = math.max(1, frameWidth - 20 - normalReservedRight)

        if shouldStackForWidth(availableTextWidth) then
            applyStackedLayout(false)
        end
    end

    Button:GetPropertyChangedSignal("AbsoluteSize"):Connect(checkOverlap)
    if LabelFunc.TitleLabel then
        LabelFunc.TitleLabel:GetPropertyChangedSignal("TextBounds"):Connect(checkOverlap)
    end
    checkOverlap()
    task.defer(checkOverlap)

    pcall(function()
        Button:SetAttribute("ExtraHeight", getCollapsedExtraHeight())

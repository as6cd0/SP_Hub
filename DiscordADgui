local function startCountdown(seconds)
    local startTime = tick()
    local duration = math.max(1, seconds)
    local step = 0.04
    local progress = 1
    while progress > 0 do
        local elapsed = tick() - startTime
        local pct = math.clamp(1 - (elapsed / duration), 0, 1)
        pcall(function()
            progressInner.Size = UDim2.new(pct, 0, 1, 0)
            secondsLabel.Text = tostring(math.ceil(pct * duration))
        end)
        if pct <= 0 then break end
        task.wait(step)
    end
    destroyUI()
end

